# Backend URL (no trailing slash). Leave blank for localhost defaults.
# Production: VITE_API_URL=https://your-backend.up.railway.app
VITE_API_URL=

# Supabase project (frontend talks directly to Supabase Auth).
# Both values are designed to be public-safe; they're protected by RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
