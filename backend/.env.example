# Get an API key at https://aistudio.google.com/app/apikey
# Without a key, Boardsmith falls back to a deterministic demo design.
GEMINI_API_KEY=

# Comma-separated list of allowed origins for CORS in production.
# Example: FRONTEND_URL=https://boardsmith.up.railway.app
FRONTEND_URL=

# Set to "1" to disable CORS origin checking (dev only — never in prod).
CORS_ALLOW_ALL=

# ─── Supabase (auth + Postgres) ──────────────────────────────────────────
# Project URL — Settings → API → Project URL
SUPABASE_URL=

# Anon (public) key — Settings → API → anon public key. Safe in frontend.
SUPABASE_ANON_KEY=

# JWT secret — Settings → API → JWT Settings. NEVER commit, NEVER expose.
SUPABASE_JWT_SECRET=

# Postgres connection string — Settings → Database → Connection string (URI).
# For production, prefer the session-mode pooler (port 5432) over the
# direct connection (db.xxxx.supabase.co:5432).
DATABASE_URL=
