# Get an API key at https://aistudio.google.com/app/apikey
# Without a key, Boardsmith falls back to a deterministic demo design.
GEMINI_API_KEY=

# Comma-separated list of allowed origins for CORS in production.
# Example: FRONTEND_URL=https://boardsmith.up.railway.app
FRONTEND_URL=

# Set to "1" to disable CORS origin checking (dev only — never in prod).
CORS_ALLOW_ALL=
